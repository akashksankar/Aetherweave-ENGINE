{
  "name": "@aetherweave/shared",
  "version": "0.1.0",
  "description": "Shared TypeScript types for AetherWeave",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./types": {
      "types": "./types.ts",
      "default": "./types.ts"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "type-check": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "rimraf": "^5.0.5"
  }
}
