# AetherWeave — Environment Variables Template
# Copy to .env and fill in real values before running.
# Never commit the real .env file to version control.

# ─── Core ────────────────────────────────────────────────────────────────────
VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/aetherweave
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_ECHO=false

# ─── Neo4j ─────────────────────────────────────────────────────────────────── 
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=yourpassword
NEO4J_DATABASE=neo4j

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=50
CACHE_TTL_SECONDS=300

# ─── Celery ──────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ─── LLM (LangGraph agents) ──────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
LLM_MODEL=gpt-4o-mini

# ─── Evolution Engine ─────────────────────────────────────────────────────────
MAX_EVOLUTION_GENERATIONS=500
DEFAULT_POPULATION_SIZE=20
EVOLUTION_TIMEOUT_SECONDS=300

# ─── Frontend (Next.js) ───────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000
